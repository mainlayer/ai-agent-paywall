# ============================================================
# AI Agent Paywall — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ============================================================

# ------ Mainlayer (required) --------------------------------

# Your Mainlayer vendor API key.
# Get one at: https://mainlayer.xyz/dashboard
MAINLAYER_API_KEY=ml_your_api_key_here

# The Mainlayer resource ID for this agent's service.
# Set this AFTER running: npm run setup
MAINLAYER_RESOURCE_ID=

# ------ Agent configuration ---------------------------------

# Port for the HTTP server
AGENT_PORT=3000

# Price per call in USDC (used during setup and displayed in /info)
AGENT_PRICE_USDC=0.01

# Slug for your resource on Mainlayer (must be unique per account)
AGENT_SLUG=ai-summarizer-agent

# Human-readable name for the agent (shown in /info)
AGENT_NAME=AI Summarizer Agent

# Description of what the agent does (shown in /info and on Mainlayer)
AGENT_DESCRIPTION=An AI agent that summarizes text on demand. Pay per call with Mainlayer.

# Optional: URL Mainlayer will call after successful payments
# AGENT_CALLBACK_URL=https://your-agent-domain.com/webhook/mainlayer
